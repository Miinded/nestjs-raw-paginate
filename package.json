{
  "name": "@miinded/nestjs-paginate",
  "version": "0.0.4",
  "repository": {
    "type": "git",
    "url": "git@gitlab.com:miinded/nestjs-paginate.git"
  },
  "description": "Pagination and filtering helper method for raw query using Nest.js framework.",
  "license": "MIT",
  "author": "Starker-xp <starker-xp@miinded.com>",
  "main": "lib/index.js",
  "typings": "lib/index.d.ts",
  "files": [
    "lib/**/*",
    "!lib/__tests__/**/*",
    "!lib/**/*.spec.*",
    "!lib/tsconfig.tsbuildinfo"
  ],
  "scripts": {
    "prebuild": "rimraf lib",
    "build": "tsc --project tsconfig.json",
    "prepare": "npm run build",
    "release": "npm run lint && npm run build && changelogen --release && npm publish && git push --follow-tags",
    "lint": "eslint .",
    "test": "jest",
    "test:watch": "jest --watchAll ",
    "test:cov": "jest --coverage",
    "test:covw": "jest --coverage  --watch",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.6",
    "@nestjs/platform-express": "^11.1.6",
    "express": "^5.1.0",
    "lodash": "^4.17.21",
    "nestjs-paginate": "^12.8.3",
    "typeorm": "0.3.27"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.36.0",
    "@nestjs/swagger": "^11.2.0",
    "@nestjs/testing": "^11.1.6",
    "@types/express": "^5.0.3",
    "@types/jest": "^30.0.0",
    "@types/lodash": "^4.17.20",
    "@types/node": "^24.6.0",
    "changelogen": "^0.6.2",
    "dotenv": "^17.2.3",
    "eslint": "^9.36.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "globals": "^16.4.0",
    "jest": "^30.2.0",
    "mysql": "^2.18.1",
    "prettier": "^3.6.2",
    "reflect-metadata": "^0.2.2",
    "rimraf": "^6.0.1",
    "rxjs": "^7.8.2",
    "ts-jest": "^29.4.4",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.45.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/lib/"
    ],
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "/lib/"
    ]
  },
  "release": {
    "branches": [
      "master"
    ]
  }
}
