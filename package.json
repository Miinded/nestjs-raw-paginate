{
  "name": "@miinded/nestjs-raw-paginate",
  "version": "0.1.0",
  "description": "Pagination and filtering helper method for raw query using Nest.js framework.",
  "license": "MIT",
  "author": "Starker-xp <starker-xp@miinded.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Miinded/nestjs-raw-paginate.git"
  },
  "bugs": {
    "url": "https://github.com/Miinded/nestjs-raw-paginate/issues"
  },
  "homepage": "https://github.com/Miinded/nestjs-raw-paginate#readme",
  "keywords": [
    "nestjs",
    "typeorm",
    "express",
    "pagination",
    "paginate",
    "raw",
    "querybuilder",
    "cursor",
    "filtering",
    "search"
  ],
  "main": "lib/index.js",
  "typings": "lib/index.d.ts",
  "files": [
    "lib/**/*",
    "!lib/__tests__/**/*",
    "!lib/**/*.spec.*",
    "!lib/tsconfig.tsbuildinfo"
  ],
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepare": "husky",
    "prebuild": "rimraf lib",
    "build": "tsc --project tsconfig.json",
    "lint": "eslint .",
    "format": "prettier --config .prettierrc.json --write .",
    "format:check": "prettier --config .prettierrc.json --check .",
    "test": "pnpm test:unit && pnpm test:int && pnpm test:e2e",
    "test:unit": "jest --passWithNoTests \"\\.unit\\.spec\\.ts$\"",
    "test:int": "jest --passWithNoTests \"\\.int\\.spec\\.ts$\"",
    "test:e2e": "jest --passWithNoTests \"\\.e2e\\.spec\\.ts$\"",
    "test:coverage": "jest --coverage --passWithNoTests",
    "test:watch": "jest --watchAll",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "barrels:check": "node ./config/check-barrels.mjs",
    "commitlint": "commitlint",
    "deps:check": "node ./config/check-dependency-policy.mjs",
    "ci:quality": "pnpm deps:check && pnpm barrels:check && pnpm lint && pnpm test:coverage && pnpm build",
    "release": "pnpm deps:check && pnpm barrels:check && pnpm lint && pnpm test:coverage && changeset version && pnpm build && changeset publish"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs,json,md,yml,yaml}": "prettier --config .prettierrc.json --write --ignore-unknown"
  },
  "peerDependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "express": "^5.0.0",
    "typeorm": "^0.3.17"
  },
  "dependencies": {
    "lodash": "^4.17.21",
    "nestjs-paginate": "^13.3.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.36.0",
    "@nestjs/common": "^11.1.6",
    "@nestjs/platform-express": "^11.1.6",
    "@nestjs/swagger": "^11.2.0",
    "@nestjs/testing": "^11.1.6",
    "@types/express": "^5.0.3",
    "@types/jest": "^30.0.0",
    "@types/lodash": "^4.17.20",
    "@types/node": "^24.6.0",
    "dotenv": "^17.2.3",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "express": "^5.1.0",
    "globals": "^16.4.0",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "lint-staged": "^17.0.7",
    "mysql": "^2.18.1",
    "prettier": "^3.6.2",
    "reflect-metadata": "^0.2.2",
    "rimraf": "^6.0.1",
    "rxjs": "^7.8.2",
    "ts-jest": "^29.4.4",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "typeorm": "0.3.27",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.45.0"
  },
  "jest": {
    "maxWorkers": 1,
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/lib/"
    ],
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "/lib/"
    ]
  }
}
